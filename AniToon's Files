<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AniToon's Files</title>

<style>
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Segoe UI', sans-serif;
}

body {
    background: #050816;
    color: white;
}

/* HEADER */
.header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 15px 30px;
    background: #0a0f2c;
    border-bottom: 1px solid rgba(255,255,255,0.1);
}

.logo {
    font-size: 26px;
    font-weight: bold;
    background: linear-gradient(90deg, #8a2be2, #00ffff);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}

.nav-buttons {
    display: flex;
    gap: 15px;
}

.nav-buttons button {
    padding: 8px 15px;
    border: none;
    border-radius: 8px;
    background: #11163a;
    color: white;
    cursor: pointer;
    transition: 0.3s;
}

.nav-buttons button:hover {
    background: #8a2be2;
}

.premium {
    background: linear-gradient(45deg, #ff00ff, #00ffff);
    font-weight: bold;
}

/* SIDEBAR */
.sidebar {
    position: fixed;
    top: 70px;
    left: 0;
    width: 200px;
    height: 100%;
    background: #0a0f2c;
    padding: 20px;
}

.sidebar button {
    width: 100%;
    margin-bottom: 15px;
    padding: 10px;
    border: none;
    border-radius: 10px;
    background: #11163a;
    color: white;
    cursor: pointer;
}

.sidebar button:hover {
    background: #00ffff;
    color: black;
}

/* MAIN */
.main {
    margin-left: 220px;
    padding: 30px;
}

/* HERO */
.hero {
    background: linear-gradient(120deg, #0a0f2c, #1b1f4a);
    border-radius: 15px;
    padding: 40px;
    margin-bottom: 30px;
    box-shadow: 0 0 20px rgba(0,255,255,0.2);
}

.hero h1 {
    font-size: 40px;
    margin-bottom: 10px;
}

.hero p {
    color: #aaa;
    margin-bottom: 20px;
}

.hero button {
    padding: 12px 20px;
    border: none;
    border-radius: 10px;
    background: #8a2be2;
    color: white;
    cursor: pointer;
}

/* CATEGORY CARDS */
.categories {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
}

.card {
    background: #0a0f2c;
    padding: 25px;
    border-radius: 15px;
    text-align: center;
    cursor: pointer;
    transition: 0.3s;
    border: 1px solid rgba(255,255,255,0.1);
}

.card:hover {
    transform: scale(1.05);
    box-shadow: 0 0 20px #00ffff;
}

.card h3 {
    margin-top: 10px;
}

/* FEATURES */
.features {
    margin-top: 40px;
    display: flex;
    justify-content: space-between;
}

.feature {
    background: #0a0f2c;
    padding: 20px;
    border-radius: 15px;
    width: 23%;
    text-align: center;
}

</style>
</head>

<body>

<!-- HEADER -->
<div class="header">
    <div class="logo">AniToon's Files</div>

    <div class="nav-buttons">
        <button class="premium">Premium</button>
        <button>Downloads</button>
        <button>Notifications</button>
        <button>Settings ⚙️</button>
    </div>
</div>

<!-- SIDEBAR -->
<div class="sidebar">
    <button>🏠 Home</button>
    <button>🎬 Movies</button>
    <button>📺 Web-Series</button>
    <button>🐱 Animes</button>
    <button>🎨 Cartoons</button>
</div>

<!-- MAIN -->
<div class="main">

    <!-- HERO -->
    <div class="hero">
        <h1>WELCOME TO AniToon's Files</h1>
        <p>Your Ultimate Entertainment Hub</p>
        <button>Explore Now</button>
    </div>

    <!-- CATEGORIES -->
    <div class="categories">
        <div class="card">
            🎬
            <h3>Movies</h3>
        </div>

        <div class="card">
            📺
            <h3>Web-Series</h3>
        </div>

        <div class="card">
            🐱
            <h3>Animes</h3>
        </div>

        <div class="card">
            🎨
            <h3>Cartoons</h3>
        </div>
    </div>

    <!-- FEATURES -->
    <div class="features">
        <div class="feature">⚡ Fast Streaming</div>
        <div class="feature">🔒 100% Secure</div>
        <div class="feature">⬇️ Download Option</div>
        <div class="feature">💎 Premium Experience</div>
    </div>

</div>

</body>
</html>
